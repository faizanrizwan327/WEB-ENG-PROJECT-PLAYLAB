<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile - PlayHub</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
  <nav class="navbar navbar-expand-lg">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center gap-2" href="/">
        <div class="brand-icon"><i class="fas fa-gamepad"></i></div>
        <span>PlayHub</span>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/games"><i class="fas fa-th-large me-1"></i>Games</a></li>
          <li class="nav-item"><a class="nav-link" href="/games/upload"><i class="fas fa-cloud-upload-alt me-1"></i>Upload</a></li>
        </ul>
        <ul class="navbar-nav align-items-center">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 active" href="#" role="button" data-bs-toggle="dropdown">
              <div class="avatar-sm"><%= user.username.charAt(0).toUpperCase() %></div>
              <span><%= user.username %></span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0">
              <li><a class="dropdown-item active" href="/auth/profile"><i class="fas fa-user me-2 text-primary"></i>Profile</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item text-danger" href="/auth/logout"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
            </ul>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <main class="flex-grow-1 py-5">
    <div class="container">
      <div class="row g-4">
        <!-- Profile Sidebar -->
        <div class="col-lg-4">
          <div class="profile-card fade-in">
            <div class="profile-avatar"><%= user.username.charAt(0).toUpperCase() %></div>
            <div class="profile-name"><%= user.username %></div>
            <div class="profile-email"><i class="fas fa-envelope me-1"></i><%= user.email %></div>
            <div class="profile-stats">
              <div class="stat">
                <div class="stat-value"><%= userGames.length %></div>
                <div class="stat-label">Games</div>
              </div>
              <div class="stat">
                <div class="stat-value"><%= new Date(user.createdAt).getFullYear() %></div>
                <div class="stat-label">Member</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Games Section -->
        <div class="col-lg-8">
          <div class="d-flex align-items-center justify-content-between mb-4">
            <h3 class="mb-0 fw-bold"><i class="fas fa-gamepad me-2 text-primary"></i>Your Uploaded Games</h3>
            <a href="/games/upload" class="btn btn-primary btn-sm">
              <i class="fas fa-plus me-1"></i>New Game
            </a>
          </div>

          <% if (userGames.length === 0) { %>
            <div class="card shadow-sm border-0">
              <div class="card-body text-center py-5">
                <div class="empty-state-icon mx-auto mb-3" style="width: 80px; height: 80px; font-size: 2rem;">
                  <i class="fas fa-upload"></i>
                </div>
                <h5>No games yet</h5>
                <p class="text-muted mb-3">You haven't uploaded any games. Start sharing your creations!</p>
                <a href="/games/upload" class="btn btn-primary"><i class="fas fa-cloud-upload-alt me-2"></i>Upload Your First Game</a>
              </div>
            </div>
          <% } else { %>
            <div class="row">
              <% userGames.forEach((game, index) => { %>
                <div class="col-md-6 mb-4">
                  <div class="card h-100 game-card fade-in stagger-<%= (index % 6) + 1 %>">
                    <div class="game-thumbnail" style="height: 140px;">
                      <i class="fas fa-gamepad text-primary" style="opacity: 0.4; font-size: 2.5rem;"></i>
                    </div>
                    <div class="card-body d-flex flex-column">
                      <h5 class="card-title mb-2"><%= game.title %></h5>
                      <p class="card-text flex-grow-1 text-muted" style="font-size: 0.9rem;"><%= game.description || 'No description' %></p>
                      <div class="btn-group-game mt-3">
                        <a href="/games/<%= game._id %>/play" class="btn btn-primary">
                          <i class="fas fa-play me-1"></i>Play
                        </a>
                        <a href="/games/<%= game._id %>/edit" class="btn btn-outline-secondary">
                          <i class="fas fa-pen"></i>
                        </a>
                        <button type="button" class="btn btn-danger delete-game-btn" data-game-id="<%= game._id %>">
                          <i class="fas fa-trash"></i>
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              <% }); %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </main>

  <footer class="footer">
    <div class="container text-center">
      <p class="mb-0">&copy; 2026 PlayHub. All rights reserved. | Built for SE3542 Web Engineering</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
  <script>
    document.querySelectorAll('.delete-game-btn').forEach(btn => {
      btn.addEventListener('click', async function() {
        if (!confirm('Are you sure you want to delete this game? This action cannot be undone.')) return;
        const gameId = this.dataset.gameId;
        try {
          const response = await fetch(`/games/${gameId}/delete`, { method: 'DELETE' });
          if (response.ok) {
            location.reload();
          } else {
            const data = await response.json();
            alert(data.error || 'Error deleting game');
          }
        } catch (err) {
          alert('Error deleting game: ' + err);
        }
      });
    });
  </script>
</body>
</html>

