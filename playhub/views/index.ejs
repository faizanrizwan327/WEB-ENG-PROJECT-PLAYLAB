<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PlayHub - Free Games Platform</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
  <nav class="navbar navbar-expand-lg">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center gap-2" href="/">
        <div class="brand-icon"><i class="fas fa-gamepad"></i></div>
        <span>PlayHub</span>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/games"><i class="fas fa-th-large me-1"></i>Games</a></li>
          <% if (user) { %>
            <li class="nav-item"><a class="nav-link" href="/games/upload"><i class="fas fa-cloud-upload-alt me-1"></i>Upload</a></li>
          <% } %>
        </ul>
        <ul class="navbar-nav align-items-center">
          <% if (user) { %>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" role="button" data-bs-toggle="dropdown">
                <div class="avatar-sm"><%= user.username.charAt(0).toUpperCase() %></div>
                <span><%= user.username %></span>
              </a>
              <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0">
                <li><a class="dropdown-item" href="/auth/profile"><i class="fas fa-user me-2 text-primary"></i>Profile</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger" href="/auth/logout"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
              </ul>
            </li>
          <% } else { %>
            <li class="nav-item"><a class="nav-link" href="/auth/login">Login</a></li>
            <li class="nav-item"><a class="btn btn-primary btn-sm ms-2" href="/auth/register">Register</a></li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <main class="flex-grow-1">
    <!-- Hero Section -->
    <div class="hero">
      <div class="container">
        <% if (typeof messages !== 'undefined' && messages && messages.error && messages.error.length) { %>
          <div class="alert alert-danger fade-in mb-4"><%= messages.error[0] %></div>
        <% } %>
        <% if (typeof messages !== 'undefined' && messages && messages.success && messages.success.length) { %>
          <div class="alert alert-success fade-in mb-4"><%= messages.success[0] %></div>
        <% } %>
        <div class="row align-items-center">
          <div class="col-lg-7">
            <h1>Discover Amazing Free Games</h1>
            <p class="lead">Join our community of gamers and developers. Play incredible games created by talented developers from around the world.</p>
            <div class="d-flex flex-wrap gap-3">
              <a href="/games" class="btn btn-light btn-lg">
                <i class="fas fa-th-large me-2"></i>Browse Games
              </a>
              <% if (!user) { %>
                <a href="/auth/register" class="btn btn-outline-light btn-lg">
                  <i class="fas fa-rocket me-2"></i>Join Community
                </a>
              <% } else { %>
                <a href="/games/upload" class="btn btn-outline-light btn-lg">
                  <i class="fas fa-cloud-upload-alt me-2"></i>Upload Game
                </a>
              <% } %>
            </div>
          </div>
          <div class="col-lg-5 d-none d-lg-block">
            <div class="stat-card">
              <h4 class="text-white mb-4"><i class="fas fa-chart-bar me-2"></i>Platform Stats</h4>
              <div class="row text-center g-3">
                <div class="col-4">
                  <div class="h2 text-white mb-1">100+</div>
                  <small class="text-white-50">Games</small>
                </div>
                <div class="col-4">
                  <div class="h2 text-white mb-1">50+</div>
                  <small class="text-white-50">Developers</small>
                </div>
                <div class="col-4">
                  <div class="h2 text-white mb-1">&infin;</div>
                  <small class="text-white-50">Fun</small>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Features Section -->
    <div class="container my-5">
      <div class="text-center mb-5">
        <h2 class="fw-bold">Why PlayHub?</h2>
        <p class="text-muted">Everything you need to play and share games</p>
      </div>
      <div class="row g-4">
        <div class="col-md-4">
          <div class="card h-100 text-center slide-up stagger-1">
            <div class="card-body p-4">
              <div class="icon-circle mx-auto mb-3" style="background: linear-gradient(135deg, #e0e7ff, #c7d2fe); color: var(--primary); width: 72px; height: 72px; font-size: 1.6rem;">
                <i class="fas fa-gamepad"></i>
              </div>
              <h4 class="fw-bold mb-2">Play Games</h4>
              <p class="text-muted mb-0">Enjoy a vast collection of free HTML5 games from our talented community.</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card h-100 text-center slide-up stagger-2">
            <div class="card-body p-4">
              <div class="icon-circle mx-auto mb-3" style="background: linear-gradient(135deg, #ecfdf5, #d1fae5); color: var(--success); width: 72px; height: 72px; font-size: 1.6rem;">
                <i class="fas fa-cloud-upload-alt"></i>
              </div>
              <h4 class="fw-bold mb-2">Upload Games</h4>
              <p class="text-muted mb-0">Share your own game creations with the world in just a few clicks.</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card h-100 text-center slide-up stagger-3">
            <div class="card-body p-4">
              <div class="icon-circle mx-auto mb-3" style="background: linear-gradient(135deg, #fef3c7, #fde68a); color: var(--warning); width: 72px; height: 72px; font-size: 1.6rem;">
                <i class="fas fa-users"></i>
              </div>
              <h4 class="fw-bold mb-2">Community</h4>
              <p class="text-muted mb-0">Connect with fellow gamers and developers. Be part of something amazing!</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="container mb-5">
      <div class="card border-0 shadow-lg overflow-hidden" style="background: linear-gradient(135deg, var(--primary), var(--info)); border-radius: var(--radius-xl);">
        <div class="card-body p-5 text-center text-white">
          <h3 class="fw-bold mb-3">Ready to start playing?</h3>
          <p class="mb-4 opacity-75">Join thousands of players and developers on PlayHub today.</p>
          <a href="/games" class="btn btn-light btn-lg">
            <i class="fas fa-play me-2"></i>Start Playing
          </a>
        </div>
      </div>
    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <div class="row">
        <div class="col-md-4 mb-4">
          <div class="d-flex align-items-center gap-2 mb-3">
            <div class="brand-icon" style="width: 32px; height: 32px; font-size: 0.9rem;"><i class="fas fa-gamepad"></i></div>
            <h5 class="mb-0">PlayHub</h5>
          </div>
          <p>Your ultimate destination for free, community-driven games. Built with passion for the gaming community.</p>
        </div>
        <div class="col-md-4 mb-4">
          <h5>Quick Links</h5>
          <ul class="list-unstyled">
            <li><a href="/games"><i class="fas fa-chevron-right me-1" style="font-size: 0.7rem;"></i>Browse Games</a></li>
            <% if (!user) { %>
              <li><a href="/auth/register"><i class="fas fa-chevron-right me-1" style="font-size: 0.7rem;"></i>Join Community</a></li>
              <li><a href="/auth/login"><i class="fas fa-chevron-right me-1" style="font-size: 0.7rem;"></i>Login</a></li>
            <% } else { %>
              <li><a href="/games/upload"><i class="fas fa-chevron-right me-1" style="font-size: 0.7rem;"></i>Upload Game</a></li>
              <li><a href="/auth/profile"><i class="fas fa-chevron-right me-1" style="font-size: 0.7rem;"></i>My Profile</a></li>
            <% } %>
          </ul>
        </div>
        <div class="col-md-4 mb-4">
          <h5>About</h5>
          <p>SE3542 Web Engineering Project<br>Built with <i class="fas fa-heart text-danger"></i> using Node.js, Express & MongoDB</p>
        </div>
      </div>
      <hr>
      <div class="text-center">
        <p class="mb-0">&copy; 2026 PlayHub. All rights reserved. | Made for SE3542 Web Engineering</p>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>

