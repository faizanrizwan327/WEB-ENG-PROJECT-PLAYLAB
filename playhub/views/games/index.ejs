<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Games - PlayHub</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
  <nav class="navbar navbar-expand-lg">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center gap-2" href="/">
        <div class="brand-icon"><i class="fas fa-gamepad"></i></div>
        <span>PlayHub</span>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link active" href="/games"><i class="fas fa-th-large me-1"></i>Games</a></li>
          <% if (user) { %>
            <li class="nav-item"><a class="nav-link" href="/games/upload"><i class="fas fa-cloud-upload-alt me-1"></i>Upload</a></li>
          <% } %>
        </ul>
        <ul class="navbar-nav align-items-center">
          <li class="nav-item">
            <button class="dark-mode-toggle" onclick="toggleDarkMode()" title="Toggle Dark Mode">
              <i class="fas fa-moon"></i>
            </button>
          </li>
          <% if (typeof user !== 'undefined' && user) { %>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" role="button" data-bs-toggle="dropdown">
                <div class="avatar-sm"><%= user.username.charAt(0).toUpperCase() %></div>
                <span><%= user.username %></span>
              </a>
              <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0">
                <li><a class="dropdown-item" href="/auth/profile"><i class="fas fa-user me-2 text-primary"></i>Profile</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger" href="/auth/logout"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
              </ul>
            </li>
          <% } else { %>
            <li class="nav-item"><a class="nav-link" href="/auth/login">Login</a></li>
            <li class="nav-item"><a class="btn btn-primary btn-sm ms-2" href="/auth/register">Register</a></li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <main class="flex-grow-1">
    <!-- Hero Header -->
    <div class="hero" style="padding: 60px 0 50px;">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-lg-8">
            <h1><i class="fas fa-gamepad me-3"></i>Game Library</h1>
            <p class="lead mb-0">Discover amazing games created by our talented community of developers.</p>
          </div>
          <div class="col-lg-4 text-lg-end mt-4 mt-lg-0">
            <% if (user) { %>
              <a href="/games/upload" class="btn btn-light btn-lg">
                <i class="fas fa-plus me-2"></i>Upload New Game
              </a>
            <% } else { %>
              <a href="/auth/login" class="btn btn-light btn-lg">
                <i class="fas fa-sign-in-alt me-2"></i>Login to Upload
              </a>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <div class="container my-5">
      <!-- Alerts -->
      <% if (messages && messages.error && messages.error.length) { %>
        <div class="alert alert-danger fade-in mb-4"><%= messages.error[0] %></div>
      <% } %>
      <% if (messages && messages.success && messages.success.length) { %>
        <div class="alert alert-success fade-in mb-4"><%= messages.success[0] %></div>
      <% } %>

      <!-- Search & Filter Panel -->
      <div class="filter-panel mb-5">
        <div class="row align-items-end g-3">
          <!-- Search Bar -->
          <div class="col-md-12 col-lg-4">
            <label class="form-label fw-600"><i class="fas fa-search me-2"></i>Search Games</label>
            <input type="text" class="form-control form-control-lg" id="gameSearch" placeholder="Search by title or description...">
          </div>

          <!-- Category Filter -->
          <div class="col-md-6 col-lg-3">
            <label class="form-label fw-600"><i class="fas fa-filter me-2"></i>Category</label>
            <select class="form-select form-select-lg" id="categoryFilter" onchange="applyFilters()">
              <option value="">All Categories</option>
              <option value="Puzzle">Puzzle</option>
              <option value="Action">Action</option>
              <option value="Adventure">Adventure</option>
              <option value="Strategy">Strategy</option>
              <option value="Casual">Casual</option>
              <option value="Educational">Educational</option>
            </select>
          </div>

          <!-- Sort Options -->
          <div class="col-md-6 col-lg-3">
            <label class="form-label fw-600"><i class="fas fa-sort-amount-down me-2"></i>Sort By</label>
            <select class="form-select form-select-lg" id="sortFilter" onchange="applyFilters()">
              <option value="">Newest</option>
              <option value="popular">Most Popular (Views)</option>
              <option value="rating">Top Rated</option>
            </select>
          </div>

          <!-- Favorites Button -->
          <div class="col-md-12 col-lg-2">
            <% if (user) { %>
              <a href="/games/favorites" class="btn btn-info btn-lg w-100">
                <i class="fas fa-heart me-2"></i>My Favorites
              </a>
            <% } %>
          </div>
        </div>
      </div>

      <% if (games.length === 0) { %>
        <div class="empty-state">
          <div class="empty-state-icon"><i class="fas fa-ghost"></i></div>
          <h3>No games available yet</h3>
          <p>Be the first to share your creation with the world!</p>
          <% if (!user) { %>
            <a href="/auth/login" class="btn btn-primary btn-lg"><i class="fas fa-sign-in-alt me-2"></i>Login to Upload</a>
          <% } else { %>
            <a href="/games/upload" class="btn btn-primary btn-lg"><i class="fas fa-cloud-upload-alt me-2"></i>Upload Game</a>
          <% } %>
        </div>
      <% } else { %>
        <div class="row" id="gamesGrid">
          <% games.forEach((game, index) => { %>
            <div class="col-md-6 col-lg-4 mb-4 game-item" data-title="<%= game.title.toLowerCase() %>" data-category="<%= game.category || '' %>">
              <div class="card h-100 game-card fade-in stagger-<%= (index % 6) + 1 %>">
                <div class="game-thumbnail">
                  <i class="fas fa-gamepad text-primary" style="opacity: 0.4;"></i>
                </div>
                <div class="card-body d-flex flex-column">
                  <div class="game-meta">
                    <i class="fas fa-user-circle"></i>
                    <span><%= game.uploadedBy.username %></span>
                    <span class="ms-auto"><i class="far fa-clock me-1"></i><%= new Date(game.createdAt).toLocaleDateString() %></span>
                  </div>
                  <h5 class="card-title"><%= game.title %></h5>
                  <p class="card-text flex-grow-1"><%= game.description || 'No description available.' %></p>
                  
                  <!-- Game Stats -->
                  <div class="py-2 mb-3">
                    <small class="text-muted d-block"><i class="fas fa-eye me-1"></i><%= game.views %> views</small>
                    <% if (game.avgRating) { %>
                      <small class="text-warning d-block"><i class="fas fa-star me-1"></i><%= game.avgRating.toFixed(1) %> rating</small>
                    <% } %>
                    <% if (game.category) { %>
                      <small class="d-block"><span class="badge bg-info"><%= game.category %></span></small>
                    <% } %>
                  </div>

                  <div class="mt-auto">
                    <div class="btn-group-game">
                      <a href="/games/<%= game._id %>/play" class="btn btn-primary">
                        <i class="fas fa-play me-1"></i>Play
                      </a>
                      <% if (user && game.uploadedBy._id.toString() === user._id.toString()) { %>
                        <a href="/games/<%= game._id %>/edit" class="btn btn-outline-secondary">
                          <i class="fas fa-pen"></i>
                        </a>
                        <button type="button" class="btn btn-danger delete-game-btn" data-game-id="<%= game._id %>">
                          <i class="fas fa-trash"></i>
                        </button>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% }); %>
        </div>

        <!-- Pagination -->
        <% if (typeof totalPages !== 'undefined' && totalPages && totalPages > 1) { %>
          <nav aria-label="Page navigation" class="mt-5">
            <ul class="pagination justify-content-center">
              <% if (page > 1) { %>
                <li class="page-item">
                  <a class="page-link" href="?page=1<%= search ? '&search=' + search : '' %><%= category ? '&category=' + category : '' %><%= sort ? '&sort=' + sort : '' %>">
                    <i class="fas fa-chevron-left me-1"></i>First
                  </a>
                </li>
                <li class="page-item">
                  <a class="page-link" href="?page=<%= Number(page) - 1 %><%= search ? '&search=' + search : '' %><%= category ? '&category=' + category : '' %><%= sort ? '&sort=' + sort : '' %>">
                    Previous
                  </a>
                </li>
              <% } %>

              <% for (let i = Math.max(1, Number(page) - 2); i <= Math.min(totalPages, Number(page) + 2); i++) { %>
                <% if (i === Number(page)) { %>
                  <li class="page-item active">
                    <span class="page-link"><%= i %></span>
                  </li>
                <% } else { %>
                  <li class="page-item">
                    <a class="page-link" href="?page=<%= i %><%= search ? '&search=' + search : '' %><%= category ? '&category=' + category : '' %><%= sort ? '&sort=' + sort : '' %>">
                      <%= i %>
                    </a>
                  </li>
                <% } %>
              <% } %>

              <% if (Number(page) < totalPages) { %>
                <li class="page-item">
                  <a class="page-link" href="?page=<%= Number(page) + 1 %><%= search ? '&search=' + search : '' %><%= category ? '&category=' + category : '' %><%= sort ? '&sort=' + sort : '' %>">
                    Next
                  </a>
                </li>
                <li class="page-item">
                  <a class="page-link" href="?page=<%= totalPages %><%= search ? '&search=' + search : '' %><%= category ? '&category=' + category : '' %><%= sort ? '&sort=' + sort : '' %>">
                    Last <i class="fas fa-chevron-right ms-1"></i>
                  </a>
                </li>
              <% } %>
            </ul>
          </nav>
        <% } %>
      <% } %>
    </div>
  </main>

  <footer class="footer">
    <div class="container text-center">
      <p class="mb-0">&copy; 2026 PlayHub. All rights reserved. | Built for SE3542 Web Engineering</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
  <script src="/js/features.js"></script>
  <script>
    // Apply filters and pagination
    function applyFilters() {
      const search = document.getElementById('gameSearch').value;
      const category = document.getElementById('categoryFilter').value;
      const sort = document.getElementById('sortFilter').value;
      
      let url = '/games?page=1';
      if (search) url += '&search=' + encodeURIComponent(search);
      if (category) url += '&category=' + encodeURIComponent(category);
      if (sort) url += '&sort=' + encodeURIComponent(sort);
      
      window.location.href = url;
    }

    // Search functionality with keyboard events
    document.getElementById('gameSearch')?.addEventListener('keyup', function() {
      clearTimeout(this.searchTimeout);
      this.searchTimeout = setTimeout(() => {
        applyFilters();
      }, 500);
    });

    // Delete functionality
    document.querySelectorAll('.delete-game-btn').forEach(btn => {
      btn.addEventListener('click', async function() {
        if (!confirm('Are you sure you want to delete this game? This action cannot be undone.')) return;
        const gameId = this.dataset.gameId;
        try {
          const response = await fetch(`/games/${gameId}/delete`, { method: 'DELETE' });
          if (response.ok) {
            location.reload();
          } else {
            const data = await response.json();
            alert(data.error || 'Error deleting game');
          }
        } catch (err) {
          alert('Error deleting game: ' + err);
        }
      });
    });

    // Set current filter values from URL params
    window.addEventListener('load', function() {
      const params = new URLSearchParams(window.location.search);
      const search = params.get('search');
      const category = params.get('category');
      const sort = params.get('sort');
      
      if (search) document.getElementById('gameSearch').value = search;
      if (category) document.getElementById('categoryFilter').value = category;
      if (sort) document.getElementById('sortFilter').value = sort;
    });
  </script>
</body>
</html>

