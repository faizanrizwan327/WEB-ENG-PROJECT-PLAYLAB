<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= game.title %> - PlayHub</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
  <nav class="navbar navbar-expand-lg">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center gap-2" href="/">
        <div class="brand-icon"><i class="fas fa-gamepad"></i></div>
        <span>PlayHub</span>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/games"><i class="fas fa-th-large me-1"></i>Games</a></li>
          <% if (typeof user !== 'undefined' && user) { %>
            <li class="nav-item"><a class="nav-link" href="/games/upload"><i class="fas fa-cloud-upload-alt me-1"></i>Upload</a></li>
          <% } %>
        </ul>
        <ul class="navbar-nav align-items-center">
          <% if (typeof user !== 'undefined' && user) { %>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" role="button" data-bs-toggle="dropdown">
                <div class="avatar-sm"><%= user.username.charAt(0).toUpperCase() %></div>
                <span><%= user.username %></span>
              </a>
              <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0">
                <li><a class="dropdown-item" href="/auth/profile"><i class="fas fa-user me-2 text-primary"></i>Profile</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger" href="/auth/logout"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
              </ul>
            </li>
          <% } else { %>
            <li class="nav-item"><a class="nav-link" href="/auth/login">Login</a></li>
            <li class="nav-item"><a class="btn btn-primary btn-sm ms-2" href="/auth/register">Register</a></li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <main class="flex-grow-1 py-4">
    <div class="container">
      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/"><i class="fas fa-home me-1"></i>Home</a></li>
          <li class="breadcrumb-item"><a href="/games">Games</a></li>
          <li class="breadcrumb-item active" aria-current="page"><%= game.title %></li>
        </ol>
      </nav>

      <!-- Game Info Card -->
      <div class="card shadow-lg border-0 mb-4">
        <div class="card-body p-4">
          <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
            <div class="d-flex align-items-center gap-3">
              <div class="icon-circle" style="background: linear-gradient(135deg, var(--primary), var(--info)); width: 56px; height: 56px; font-size: 1.3rem;">
                <i class="fas fa-gamepad"></i>
              </div>
              <div>
                <h2 class="mb-1" style="font-weight: 800;"><%= game.title %></h2>
                <p class="mb-0 text-muted"><i class="fas fa-user me-1"></i>By <%= game.uploadedBy ? game.uploadedBy.username : 'Unknown' %></p>
              </div>
            </div>
            <% if (typeof user !== 'undefined' && user && game.uploadedBy && game.uploadedBy._id.toString() === user._id.toString()) { %>
              <div class="d-flex gap-2">
                <a href="/games/<%= game._id %>/edit" class="btn btn-outline-secondary">
                  <i class="fas fa-pen me-1"></i>Edit
                </a>
                <button type="button" class="btn btn-danger delete-game-btn" data-game-id="<%= game._id %>">
                  <i class="fas fa-trash me-1"></i>Delete
                </button>
              </div>
            <% } %>
          </div>
          <% if (game.description) { %>
            <hr class="my-4">
            <p class="mb-0 text-secondary"><%= game.description %></p>
          <% } %>
        </div>
      </div>

      <!-- Game Frame -->
      <div class="game-frame-container">
        <iframe src="/games/<%= game.filePath %>" class="game-iframe" title="<%= game.title %>"></iframe>
      </div>
    </div>
  </main>

  <footer class="footer">
    <div class="container text-center">
      <p class="mb-0">&copy; 2026 PlayHub. All rights reserved. | Built for SE3542 Web Engineering</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
  <script>
    document.querySelectorAll('.delete-game-btn').forEach(btn => {
      btn.addEventListener('click', async function() {
        if (!confirm('Are you sure you want to delete this game? This action cannot be undone.')) return;
        const gameId = this.dataset.gameId;
        try {
          const response = await fetch(`/games/${gameId}/delete`, { method: 'DELETE' });
          if (response.ok) {
            window.location.href = '/games';
          } else {
            const data = await response.json();
            alert(data.error || 'Error deleting game');
          }
        } catch (err) {
          alert('Error deleting game: ' + err);
        }
      });
    });
  </script>
</body>
</html>

